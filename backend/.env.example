SERVICE_NAME=virtual-tryon-api
APP_VERSION=0.1.0
MAX_UPLOAD_SIZE_BYTES=10485760
ALLOWED_IMAGE_MIME_TYPES=image/jpeg,image/png,image/webp
MAX_IMAGE_DIMENSION=4096
MAX_IMAGE_PIXELS=40000000
UPLOAD_READ_CHUNK_SIZE=1048576
STORAGE_DIR=storage
GEMINI_PROVIDER=fake
GEMINI_USE_VERTEX=false
GEMINI_API_KEY=
GEMINI_PROJECT_ID=
GEMINI_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash-image
GEMINI_TEMPERATURE=0.2
GEMINI_TOP_P=0.95
GEMINI_CANDIDATE_COUNT=1
GEMINI_RESPONSE_MODALITIES=IMAGE
GEMINI_SAFETY_THRESHOLD=BLOCK_ONLY_HIGH
GEMINI_TIMEOUT_SECONDS=60
GEMINI_MAX_RETRIES=3
PREPROCESS_MAX_DIMENSION=1536
VIDEO_PROVIDER=kling
POLLINATIONS_API_KEY=
