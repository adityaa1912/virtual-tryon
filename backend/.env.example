GEMINI_TOP_P=0.95
GEMINI_CANDIDATE_COUNT=1
GEMINI_RESPONSE_MODALITIES=IMAGE
GEMINI_SAFETY_THRESHOLD=BLOCK_ONLY_HIGH
GEMINI_TIMEOUT_SECONDS=60
GEMINI_MAX_RETRIES=3
PREPROCESS_MAX_DIMENSION=1536
VIDEO_PROVIDER=fake
KLING_API_KEY=
